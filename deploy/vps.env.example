NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
LOG_LEVEL=info

# Point this to the VPS database.
DATABASE_URL=postgresql://dca_lite_user:CHANGE_ME@127.0.0.1:5432/dca_books_lite?schema=public

# Set this to the public frontend origin, without /api/v1.
CORS_ORIGIN=https://books.example.com

TRUST_PROXY_HOPS=1

# Temporary VPS staging fallback only.
STORAGE_PROVIDER=LOCAL
LOCAL_UPLOAD_DIR=storage/uploads

# Google Drive production storage is blocked until the credential strategy is chosen.
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# GOOGLE_DRIVE_ROOT_FOLDER_NAME=
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_DRIVE_PRIVATE_KEY=
# GOOGLE_DRIVE_CLIENT_EMAIL=
# GOOGLE_APPLICATION_CREDENTIALS=

ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
INVITATION_TOKEN_TTL_HOURS=72
PASSWORD_RESET_TOKEN_TTL_HOURS=2
REFRESH_COOKIE_NAME=dca_books_refresh
REFRESH_COOKIE_PATH=/api/v1/auth/refresh
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

BCRYPT_COST=12

BOOTSTRAP_TENANT_NAME=Digital Cube Agency
BOOTSTRAP_TENANT_SLUG=digital-cube-agency
BOOTSTRAP_ADMIN_EMAIL=admin@dcabooks.local
BOOTSTRAP_ALLOW_PRODUCTION=false
# BOOTSTRAP_ISSUER_DISPLAY_NAME=
# BOOTSTRAP_ISSUER_LEGAL_NAME=
# BOOTSTRAP_ISSUER_CURRENCY_CODE=USD
