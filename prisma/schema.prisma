generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  ARCHIVED
}

enum PaymentStatus {
  POSTED
  REVERSED
}

enum FileAttachmentEntityType {
  PAYMENT
  BILL
  INVOICE
}

enum StorageProvider {
  LOCAL
  GOOGLE_DRIVE
}

enum BillStatus {
  DRAFT
  OPEN
  PAID
  VOID
  ARCHIVED
}

enum RecurringInvoiceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RecurringInvoiceFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringInvoiceRunStatus {
  SUCCESS
  SKIPPED
  FAILED
}

enum AuditActorType {
  USER
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
  SESSION_REVOKED
  BOOTSTRAP_ADMIN
  INVITE
  PASSWORD_SETUP
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_CONFIRM
  ASSIGN_ROLE
  REMOVE_ROLE
  GRANT_PERMISSION
  REVOKE_PERMISSION
  SYSTEM
}

enum AuthTokenPurpose {
  INVITATION_SETUP
  PASSWORD_RESET
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(160)
  legalName String?      @map("legal_name") @db.VarChar(200)
  slug      String       @unique @db.VarChar(80)
  status    TenantStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships TenantMembership[]
  roles Role[]
  userRoles UserRole[]
  clients Client[]
  projects Project[]
  serviceItems ServiceItem[]
  invoices Invoice[]
  invoiceSequences InvoiceSequence[]
  invoiceLines InvoiceLine[]
  payments Payment[]
  vendors Vendor[]
  expenseCategories ExpenseCategory[]
  bills Bill[]
  recurringInvoices RecurringInvoice[]
  recurringInvoiceLines RecurringInvoiceLine[]
  recurringInvoiceRuns RecurringInvoiceRun[]
  issuerProfile TenantIssuerProfile?
  fileAttachments FileAttachment[]
  auditLogs AuditLog[]
  authTokens AuthToken[]

  @@index([status, deletedAt])
  @@map("tenants")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  email       String     @unique @db.Citext
  displayName String?    @map("display_name") @db.VarChar(160)
  status      UserStatus @default(ACTIVE)

  passwordHash      String?   @map("password_hash") @db.Text
  passwordUpdatedAt DateTime? @map("password_updated_at") @db.Timestamptz(6)
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  tokenVersion      Int       @default(0) @map("token_version")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships       TenantMembership[]
  roles             UserRole[]
  sessions          UserSession[]
  auditLogs         AuditLog[]
  authTokens        AuthToken[] @relation("AuthTokenUser")
  createdAuthTokens AuthToken[] @relation("AuthTokenCreatedBy")
  uploadedFileAttachments FileAttachment[]

  @@index([status, deletedAt])
  @@map("users")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.Text
  userAgent        String?   @map("user_agent") @db.VarChar(500)
  ipAddress        String?   @map("ip_address") @db.VarChar(80)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById     String?   @map("replaced_by_id") @db.Uuid
  revokedById      String?   @map("revoked_by_id") @db.Uuid
  revocationReason String?   @map("revocation_reason") @db.VarChar(50)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@index([replacedById])
  @@index([revokedById])
  @@map("user_sessions")
}

model AuthToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tenantId  String?          @map("tenant_id") @db.Uuid
  purpose   AuthTokenPurpose
  tokenHash String           @unique @map("token_hash") @db.Text

  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)

  createdById String? @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user      User    @relation("AuthTokenUser", fields: [userId], references: [id], onDelete: Restrict)
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("AuthTokenCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, purpose, consumedAt, revokedAt, expiresAt])
  @@index([tenantId, purpose, createdAt])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model TenantMembership {
  id       String           @id @default(uuid()) @db.Uuid
  tenantId String           @map("tenant_id") @db.Uuid
  userId   String           @map("user_id") @db.Uuid
  status   MembershipStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId])
  @@index([tenantId, status, deletedAt])
  @@index([userId, status, deletedAt])
  @@map("tenant_memberships")
}

model Client {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @map("tenant_id") @db.Uuid
  name     String       @db.VarChar(160)
  status   ClientStatus  @default(ACTIVE)

  email                 String?  @db.Citext
  phone                 String?  @db.VarChar(40)
  website               String?  @db.VarChar(200)
  taxId                 String?  @map("tax_id") @db.VarChar(80)
  billingAddressLine1   String?  @map("billing_address_line1") @db.VarChar(160)
  billingAddressLine2   String?  @map("billing_address_line2") @db.VarChar(160)
  billingCity           String?  @map("billing_city") @db.VarChar(120)
  billingState          String?  @map("billing_state") @db.VarChar(120)
  billingPostalCode     String?  @map("billing_postal_code") @db.VarChar(40)
  billingCountry        String?  @map("billing_country") @db.VarChar(120)
  notes                 String?  @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  projects Project[]
  invoices Invoice[]
  recurringInvoices RecurringInvoice[]

  @@index([tenantId, status, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@map("clients")
}

model Project {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  clientId String? @map("client_id") @db.Uuid
  name     String @db.VarChar(160)
  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoices Invoice[]
  recurringInvoices RecurringInvoice[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, clientId, deletedAt])
  @@map("projects")
}

model ServiceItem {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  name           String  @db.VarChar(160)
  description    String? @db.Text
  unitPriceMinor  Int    @map("unit_price_minor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoiceLines InvoiceLine[]
  recurringInvoiceLines RecurringInvoiceLine[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, unitPriceMinor])
  @@map("service_items")
}

model InvoiceSequence {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  invoiceYear  Int    @map("invoice_year")
  currentValue Int    @default(0) @map("current_value")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, invoiceYear])
  @@index([tenantId, invoiceYear])
  @@map("invoice_sequences")
}

model Invoice {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  clientId       String?      @map("client_id") @db.Uuid
  projectId      String?      @map("project_id") @db.Uuid
  invoiceNumber  String       @map("invoice_number") @db.VarChar(40)
  invoiceYear    Int          @map("invoice_year")
  invoiceSequence Int         @map("invoice_sequence")
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime     @map("issue_date") @db.Date
  dueDate        DateTime     @map("due_date") @db.Date
  notes          String?      @db.Text
  terms          String?      @db.Text
  subtotalMinor  Int          @map("subtotal_minor")
  totalMinor     Int          @map("total_minor")
  paidAmountMinor Int          @default(0) @map("paid_amount_minor")
  balanceDueMinor Int          @default(0) @map("balance_due_minor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines   InvoiceLine[]
  payments Payment[]
  generatedRecurringInvoiceRuns RecurringInvoiceRun[]

  @@unique([tenantId, invoiceNumber])
  @@unique([tenantId, invoiceYear, invoiceSequence])
  @@index([tenantId, status, deletedAt])
  @@index([tenantId, issueDate])
  @@index([tenantId, clientId, deletedAt])
  @@index([tenantId, projectId, deletedAt])
  @@map("invoices")
}

model InvoiceLine {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  invoiceId     String  @map("invoice_id") @db.Uuid
  serviceItemId String? @map("service_item_id") @db.Uuid
  lineNumber    Int     @map("line_number")
  description   String  @db.VarChar(300)
  quantity      Int
  unitPriceMinor Int    @map("unit_price_minor")
  lineTotalMinor Int    @map("line_total_minor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  serviceItem ServiceItem? @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId])
  @@index([tenantId, invoiceId, deletedAt])
  @@index([tenantId, serviceItemId])
  @@index([tenantId, invoiceId, lineNumber])
  @@map("invoice_lines")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  invoiceId     String        @map("invoice_id") @db.Uuid
  amountMinor   Int           @map("amount_minor")
  paymentDate   DateTime      @map("payment_date") @db.Date
  method        String        @db.VarChar(80)
  reference     String?       @db.VarChar(120)
  notes         String?       @db.Text
  status        PaymentStatus @default(POSTED)
  reversedAt    DateTime?     @map("reversed_at") @db.Timestamptz(6)
  reversalReason String?      @map("reversal_reason") @db.VarChar(500)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([tenantId, invoiceId])
  @@index([tenantId, invoiceId, status])
  @@index([tenantId, paymentDate])
  @@index([tenantId, status, reversedAt])
  @@map("payments")
}

model Vendor {
  id                 String  @id @default(uuid()) @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  name               String  @db.VarChar(160)
  email              String? @db.Citext
  phone              String? @db.VarChar(40)
  website            String? @db.VarChar(200)
  taxId              String? @map("tax_id") @db.VarChar(80)
  billingAddressLine1 String? @map("billing_address_line1") @db.VarChar(160)
  billingAddressLine2 String? @map("billing_address_line2") @db.VarChar(160)
  billingCity        String? @map("billing_city") @db.VarChar(120)
  billingState       String? @map("billing_state") @db.VarChar(120)
  billingPostalCode  String? @map("billing_postal_code") @db.VarChar(40)
  billingCountry     String? @map("billing_country") @db.VarChar(120)
  notes              String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  bills  Bill[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@map("vendors")
}

model ExpenseCategory {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String  @db.VarChar(160)
  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  bills  Bill[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@map("expense_categories")
}

model Bill {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  vendorId          String?   @map("vendor_id") @db.Uuid
  categoryId        String?   @map("category_id") @db.Uuid
  billNumber        String?   @map("bill_number") @db.VarChar(40)
  billDate          DateTime  @map("bill_date") @db.Date
  dueDate           DateTime? @map("due_date") @db.Date
  status            BillStatus @default(DRAFT)
  amountMinor       Int       @map("amount_minor")
  paidAmountMinor   Int       @default(0) @map("paid_amount_minor")
  balanceDueMinor   Int       @default(0) @map("balance_due_minor")
  paymentMethod     String?   @map("payment_method") @db.VarChar(80)
  paymentReference  String?   @map("payment_reference") @db.VarChar(120)
  notes             String?   @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vendor   Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  category ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([tenantId, deletedAt])
  @@index([tenantId, status, deletedAt])
  @@index([tenantId, billDate])
  @@index([tenantId, vendorId, deletedAt])
  @@index([tenantId, categoryId, deletedAt])
  @@map("bills")
}

model FileAttachment {
  id               String                  @id @default(uuid()) @db.Uuid
  tenantId         String                  @map("tenant_id") @db.Uuid
  entityType       FileAttachmentEntityType @map("entity_type")
  entityId         String                  @map("entity_id") @db.Uuid
  originalFilename String                  @map("original_filename") @db.VarChar(255)
  storedFilename   String                  @map("stored_filename") @db.VarChar(255)
  mimeType         String                  @map("mime_type") @db.VarChar(120)
  sizeBytes        Int                     @map("size_bytes")
  storageProvider  StorageProvider         @map("storage_provider")
  storageKey       String                  @map("storage_key") @db.VarChar(500)
  googleDriveFileId String?                @map("google_drive_file_id") @db.VarChar(120)
  googleDriveWebViewLink String?           @map("google_drive_web_view_link") @db.VarChar(1000)
  googleDriveWebContentLink String?        @map("google_drive_web_content_link") @db.VarChar(1000)
  checksumSha256   String?                 @map("checksum_sha256") @db.VarChar(64)
  uploadedByUserId String                  @map("uploaded_by_user_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploadedBy  User   @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, entityType, entityId, deletedAt])
  @@index([tenantId, storageProvider, deletedAt])
  @@index([tenantId, uploadedByUserId, deletedAt])
  @@map("file_attachments")
}

model TenantIssuerProfile {
  id                         String   @id @default(uuid()) @db.Uuid
  tenantId                   String   @unique @map("tenant_id") @db.Uuid
  issuerDisplayName          String   @map("issuer_display_name") @db.VarChar(160)
  issuerLegalName            String?  @map("issuer_legal_name") @db.VarChar(200)
  addressLine1               String?  @map("address_line1") @db.VarChar(160)
  addressLine2               String?  @map("address_line2") @db.VarChar(160)
  city                       String?  @db.VarChar(120)
  state                      String?  @db.VarChar(120)
  postalCode                 String?  @map("postal_code") @db.VarChar(40)
  country                    String?  @db.VarChar(120)
  email                      String?  @db.Citext
  phone                      String?  @db.VarChar(40)
  website                    String?  @db.VarChar(200)
  taxId                      String?  @map("tax_id") @db.VarChar(80)
  companyRegistrationNumber   String?  @map("company_registration_number") @db.VarChar(80)
  currencyCode               String   @map("currency_code") @db.Char(3)
  defaultInvoiceTerms        String?  @map("default_invoice_terms") @db.Text
  defaultPaymentInstructions  String?  @map("default_payment_instructions") @db.Text
  bankAccountName            String?  @map("bank_account_name") @db.VarChar(160)
  bankName                   String?  @map("bank_name") @db.VarChar(160)
  bankAccountNumber          String?  @map("bank_account_number") @db.VarChar(120)
  bankSwift                  String?  @map("bank_swift") @db.VarChar(40)
  invoiceFooter              String?  @map("invoice_footer") @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("tenant_issuer_profiles")
}

model RecurringInvoice {
  id          String                     @id @default(uuid()) @db.Uuid
  tenantId    String                     @map("tenant_id") @db.Uuid
  clientId    String?                    @map("client_id") @db.Uuid
  projectId   String?                    @map("project_id") @db.Uuid
  status      RecurringInvoiceStatus     @default(ACTIVE)
  frequency   RecurringInvoiceFrequency
  startDate   DateTime                   @map("start_date") @db.Date
  endDate     DateTime?                  @map("end_date") @db.Date
  nextRunDate DateTime                   @map("next_run_date") @db.Date
  lastRunDate DateTime?                  @map("last_run_date") @db.Date
  notes       String?                    @db.Text
  terms       String?                    @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines  RecurringInvoiceLine[]
  runs   RecurringInvoiceRun[]

  @@index([tenantId, status, deletedAt])
  @@index([tenantId, nextRunDate])
  @@index([tenantId, clientId, deletedAt])
  @@index([tenantId, projectId, deletedAt])
  @@map("recurring_invoices")
}

model RecurringInvoiceLine {
  id                 String  @id @default(uuid()) @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  recurringInvoiceId  String  @map("recurring_invoice_id") @db.Uuid
  serviceItemId      String? @map("service_item_id") @db.Uuid
  lineNumber         Int     @map("line_number")
  description        String  @db.VarChar(300)
  quantity           Int
  unitPriceMinor     Int     @map("unit_price_minor")
  lineTotalMinor     Int     @map("line_total_minor")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recurringInvoice RecurringInvoice  @relation(fields: [recurringInvoiceId], references: [id], onDelete: Restrict)
  serviceItem     ServiceItem?      @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, recurringInvoiceId])
  @@index([tenantId, recurringInvoiceId, lineNumber])
  @@index([tenantId, serviceItemId])
  @@map("recurring_invoice_lines")
}

model RecurringInvoiceRun {
  id                String                  @id @default(uuid()) @db.Uuid
  tenantId          String                  @map("tenant_id") @db.Uuid
  recurringInvoiceId String                  @map("recurring_invoice_id") @db.Uuid
  scheduledFor      DateTime                @map("scheduled_for") @db.Date
  generatedInvoiceId String?                @map("generated_invoice_id") @db.Uuid
  status            RecurringInvoiceRunStatus
  idempotencyKey    String                  @unique @map("idempotency_key") @db.VarChar(200)
  errorMessage      String?                 @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recurringInvoice RecurringInvoice  @relation(fields: [recurringInvoiceId], references: [id], onDelete: Restrict)
  generatedInvoice Invoice?          @relation(fields: [generatedInvoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, recurringInvoiceId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@map("recurring_invoice_runs")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique @db.VarChar(120)
  description String? @db.VarChar(300)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  key         String  @db.VarChar(80)
  name        String  @db.VarChar(120)
  description String? @db.VarChar(300)
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  users           UserRole[]

  @@unique([tenantId, key])
  @@unique([id, tenantId])
  @@index([tenantId, deletedAt])
  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  role   Role   @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Restrict)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId, deletedAt])
  @@index([tenantId, roleId, deletedAt])
  @@map("user_roles")
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String?        @map("tenant_id") @db.Uuid
  actorUserId String?        @map("actor_user_id") @db.Uuid
  actorType   AuditActorType @map("actor_type")
  action      AuditAction

  entityType String? @map("entity_type") @db.VarChar(120)
  entityId   String? @map("entity_id") @db.Uuid

  requestId String? @map("request_id") @db.VarChar(80)
  ipAddress String? @map("ip_address") @db.VarChar(80)
  userAgent String? @map("user_agent") @db.VarChar(500)

  beforeJson Json? @map("before")
  afterJson  Json? @map("after")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([requestId])
  @@map("audit_logs")
}
