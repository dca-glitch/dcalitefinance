generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  ARCHIVED
}

enum AuditActorType {
  USER
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
  SESSION_REVOKED
  BOOTSTRAP_ADMIN
  INVITE
  PASSWORD_SETUP
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_CONFIRM
  ASSIGN_ROLE
  REMOVE_ROLE
  GRANT_PERMISSION
  REVOKE_PERMISSION
  SYSTEM
}

enum AuthTokenPurpose {
  INVITATION_SETUP
  PASSWORD_RESET
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(160)
  legalName String?      @map("legal_name") @db.VarChar(200)
  slug      String       @unique @db.VarChar(80)
  status    TenantStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships TenantMembership[] 
  roles        Role[]
  userRoles    UserRole[]
  clients      Client[]
  projects     Project[]
  serviceItems ServiceItem[]
  invoices     Invoice[]
  invoiceSequences InvoiceSequence[]
  invoiceLines InvoiceLine[]
  auditLogs    AuditLog[]
  authTokens   AuthToken[]

  @@index([status, deletedAt])
  @@map("tenants")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  email       String     @unique @db.Citext
  displayName String?    @map("display_name") @db.VarChar(160)
  status      UserStatus @default(ACTIVE)

  passwordHash      String?   @map("password_hash") @db.Text
  passwordUpdatedAt DateTime? @map("password_updated_at") @db.Timestamptz(6)
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  tokenVersion      Int       @default(0) @map("token_version")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships       TenantMembership[]
  roles             UserRole[]
  sessions          UserSession[]
  auditLogs         AuditLog[]
  authTokens        AuthToken[] @relation("AuthTokenUser")
  createdAuthTokens AuthToken[] @relation("AuthTokenCreatedBy")

  @@index([status, deletedAt])
  @@map("users")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.Text
  userAgent        String?   @map("user_agent") @db.VarChar(500)
  ipAddress        String?   @map("ip_address") @db.VarChar(80)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById     String?   @map("replaced_by_id") @db.Uuid
  revokedById      String?   @map("revoked_by_id") @db.Uuid
  revocationReason String?   @map("revocation_reason") @db.VarChar(50)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@index([replacedById])
  @@index([revokedById])
  @@map("user_sessions")
}

model AuthToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tenantId  String?          @map("tenant_id") @db.Uuid
  purpose   AuthTokenPurpose
  tokenHash String           @unique @map("token_hash") @db.Text

  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)

  createdById String? @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user      User    @relation("AuthTokenUser", fields: [userId], references: [id], onDelete: Restrict)
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("AuthTokenCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, purpose, consumedAt, revokedAt, expiresAt])
  @@index([tenantId, purpose, createdAt])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model TenantMembership {
  id       String           @id @default(uuid()) @db.Uuid
  tenantId String           @map("tenant_id") @db.Uuid
  userId   String           @map("user_id") @db.Uuid
  status   MembershipStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId])
  @@index([tenantId, status, deletedAt])
  @@index([userId, status, deletedAt])
  @@map("tenant_memberships")
}

model Client {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @map("tenant_id") @db.Uuid
  name     String       @db.VarChar(160)
  status   ClientStatus  @default(ACTIVE)

  email                 String?  @db.Citext
  phone                 String?  @db.VarChar(40)
  website               String?  @db.VarChar(200)
  taxId                 String?  @map("tax_id") @db.VarChar(80)
  billingAddressLine1   String?  @map("billing_address_line1") @db.VarChar(160)
  billingAddressLine2   String?  @map("billing_address_line2") @db.VarChar(160)
  billingCity           String?  @map("billing_city") @db.VarChar(120)
  billingState          String?  @map("billing_state") @db.VarChar(120)
  billingPostalCode     String?  @map("billing_postal_code") @db.VarChar(40)
  billingCountry        String?  @map("billing_country") @db.VarChar(120)
  notes                 String?  @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  projects Project[]
  invoices Invoice[]

  @@index([tenantId, status, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@map("clients")
}

model Project {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  clientId String? @map("client_id") @db.Uuid
  name     String @db.VarChar(160)
  description String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, clientId, deletedAt])
  @@map("projects")
}

model ServiceItem {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  name           String  @db.VarChar(160)
  description    String? @db.Text
  unitPriceMinor  Int    @map("unit_price_minor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoiceLines InvoiceLine[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, unitPriceMinor])
  @@map("service_items")
}

model InvoiceSequence {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  invoiceYear  Int    @map("invoice_year")
  currentValue Int    @default(0) @map("current_value")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, invoiceYear])
  @@index([tenantId, invoiceYear])
  @@map("invoice_sequences")
}

model Invoice {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  clientId       String?      @map("client_id") @db.Uuid
  projectId      String?      @map("project_id") @db.Uuid
  invoiceNumber  String       @map("invoice_number") @db.VarChar(40)
  invoiceYear    Int          @map("invoice_year")
  invoiceSequence Int         @map("invoice_sequence")
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime     @map("issue_date") @db.Date
  dueDate        DateTime     @map("due_date") @db.Date
  notes          String?      @db.Text
  terms          String?      @db.Text
  subtotalMinor  Int          @map("subtotal_minor")
  totalMinor     Int          @map("total_minor")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines   InvoiceLine[]

  @@unique([tenantId, invoiceNumber])
  @@unique([tenantId, invoiceYear, invoiceSequence])
  @@index([tenantId, status, deletedAt])
  @@index([tenantId, issueDate])
  @@index([tenantId, clientId, deletedAt])
  @@index([tenantId, projectId, deletedAt])
  @@map("invoices")
}

model InvoiceLine {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  invoiceId     String  @map("invoice_id") @db.Uuid
  serviceItemId String? @map("service_item_id") @db.Uuid
  lineNumber    Int     @map("line_number")
  description   String  @db.VarChar(300)
  quantity      Int
  unitPriceMinor Int    @map("unit_price_minor")
  lineTotalMinor Int    @map("line_total_minor")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  serviceItem ServiceItem? @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId])
  @@index([tenantId, serviceItemId])
  @@index([tenantId, invoiceId, lineNumber])
  @@map("invoice_lines")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique @db.VarChar(120)
  description String? @db.VarChar(300)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  key         String  @db.VarChar(80)
  name        String  @db.VarChar(120)
  description String? @db.VarChar(300)
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  users           UserRole[]

  @@unique([tenantId, key])
  @@unique([id, tenantId])
  @@index([tenantId, deletedAt])
  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  role   Role   @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Restrict)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId, deletedAt])
  @@index([tenantId, roleId, deletedAt])
  @@map("user_roles")
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String?        @map("tenant_id") @db.Uuid
  actorUserId String?        @map("actor_user_id") @db.Uuid
  actorType   AuditActorType @map("actor_type")
  action      AuditAction

  entityType String? @map("entity_type") @db.VarChar(120)
  entityId   String? @map("entity_id") @db.Uuid

  requestId String? @map("request_id") @db.VarChar(80)
  ipAddress String? @map("ip_address") @db.VarChar(80)
  userAgent String? @map("user_agent") @db.VarChar(500)

  beforeJson Json? @map("before")
  afterJson  Json? @map("after")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([requestId])
  @@map("audit_logs")
}
